# Copy this to .env and customize.

# AnkiConnect (Anki must be running with the AnkiConnect add-on)
ANKI_CONNECT_URL=http://127.0.0.1:8765
ANKI_CONNECT_VERSION=6

# API server
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (where the frontend runs)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Currently not using.
# Encryption key for stored API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# Logging (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Set to true to log raw card content (sensitive — keep false in production)
LOG_CARD_CONTENT=false
